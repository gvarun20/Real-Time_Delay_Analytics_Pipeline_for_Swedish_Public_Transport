# Docker Compose project name (container prefix: transit-delay-pipeline-*)
COMPOSE_PROJECT_NAME=transit-delay-pipeline

# --- Trafiklab API keys (separate keys per product on developer.trafiklab.se) ---
# Static:  from "GTFS Sweden 3 Static data"  (or use GTFS Regional Static + STATIC_FEED=gtfs_regional)
TRAFIKLAB_STATIC_API_KEY=your_static_key_here

# Realtime: from "GTFS Regional Realtime"
TRAFIKLAB_REALTIME_API_KEY=your_realtime_key_here

# Optional fallback if you only have one key
TRAFIKLAB_API_KEY=

# Static feed type: gtfs_sweden_3 (default) | gtfs_regional
STATIC_FEED=gtfs_sweden_3

# Realtime feed type: gtfs_regional (default) | gtfs_sweden
REALTIME_FEED=gtfs_regional

# Operator abbreviation (sl = Stockholm, otraf = Östgötatrafiken)
OPERATOR=sl
OPERATOR_NAME=SL

# Paths (defaults work for local + Docker)
DATA_RAW_DIR=data/raw
PROJECT_ROOT=.

# Analytics Postgres (star schema)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=transit_dw
POSTGRES_USER=transit
POSTGRES_PASSWORD=transit

# Airflow (Docker)
AIRFLOW_UID=50000
